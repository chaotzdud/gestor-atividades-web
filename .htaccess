RewriteEngine On

# Exceções para arquivos e diretórios reais
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Rotas da API: /api/*
RewriteRule ^api/.*$ index.php [QSA,L]

# Rotas de página amigáveis (ex: /signup)
RewriteRule ^([a-zA-Z0-9_-]+)$ frontend/pages/$1.html [L]

# Fallback
RewriteRule ^ index.php [QSA,L]
